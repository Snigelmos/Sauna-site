---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { SITE } from "@config/site";

const title = "About Home Sauna Guide";
const description =
  "Home Sauna Guide is an independent home-sauna research desk. Learn who we are, what we stand for, and how to reach us.";
---

<BaseLayout title={title} description={description} type="article">
  <section class="editorial-container py-10">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "About" }]} />
    <div class="prose prose-lg max-w-3xl">
      <h1>About {SITE.name}</h1>
      <p>
        {SITE.name} is an independent buyer-guide site focused on one thing: helping people choose and
        plan a home sauna without the marketing fog. We are not a manufacturer and we do not sell
        saunas. We write the guide we wished existed when we started researching this category.
      </p>

      <h2>Who writes this</h2>
      <p>
        Guides are produced by the {SITE.author.name}, an independent research desk. We write from
        manufacturer specifications, independent expert reviews, electrical and building-code
        references, peer-reviewed research, and verified owner feedback. We use a neutral team byline
        on purpose - we do not invent a named "expert" or fabricate credentials. As we add first-hand
        testing, we will attribute and date those notes clearly.
      </p>

      <h2>What we stand for</h2>
      <ul>
        <li>People-first guides, not thin AI filler.</li>
        <li>No fabricated testing, ownership, ratings, or expert review.</li>
        <li>Conservative, cited health information - no detox, weight-loss, or cure claims.</li>
        <li>Every affiliate link disclosed; recommendations never for sale.</li>
      </ul>
      <p>
        See exactly how we work on our <a href="/methodology/">methodology page</a>, and how we handle
        affiliate links in our <a href="/disclosure/">disclosure</a>.
      </p>

      <h2>Contact</h2>
      <p>
        Corrections, questions, or feedback are genuinely welcome - they make the guides better. Email
        <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a> or use our
        <a href="/contact/">contact page</a>.
      </p>
    </div>
  </section>
</BaseLayout>
