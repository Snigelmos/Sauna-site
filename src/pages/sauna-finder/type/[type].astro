---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import SaunaCard from "@components/finder/SaunaCard.astro";
import FinderMap from "@components/finder/FinderMap.astro";
import {
  SAUNAS,
  TYPE_LABELS,
  cityHubs,
  typeHubs,
  type Sauna,
  type SaunaType,
} from "@data/saunas";
import {
  buildGraph,
  organizationNode,
  websiteNode,
  breadcrumbNode,
  itemListNode,
  faqNode,
} from "@components/schema/helpers";

const TYPE_INTRO: Record<SaunaType, string> = {
  allman: "Public saunas with drop-in or booking - bathe alongside others.",
  kallbadhus: "Cold bath houses pair a hot sauna with an icy dip in the sea or a lake.",
  spa: "Spas and bath houses with sauna, pools and relaxation.",
  uthyrning: "Private saunas you rent for your own group.",
  flytande: "Floating saunas on a raft or jetty - dip straight into the water.",
  hotell: "Hotel saunas, often open for day visits.",
};

export function getStaticPaths() {
  return typeHubs().map(({ type }) => ({
    params: { type },
    props: { type },
  }));
}

interface Props {
  type: SaunaType;
}
const { type } = Astro.props;
const label = TYPE_LABELS[type];

const list: Sauna[] = SAUNAS.filter((s) => s.type === type).sort(
  (a, b) =>
    Number(!!b.featured) - Number(!!a.featured) ||
    a.city.localeCompare(b.city, "sv") ||
    a.name.localeCompare(b.name, "sv")
);
const count = list.length;
const cityCount = new Set(list.map((s) => s.city)).size;

const citiesHere = cityHubs(1)
  .filter((c) => list.some((s) => s.city === c.city))
  .slice(0, 14);
const otherTypes = typeHubs().filter((t) => t.type !== type);

const labelLc = label.toLowerCase();
const title = `${label}s in Sweden - ${count} on the map`;
const description = `Find ${labelLc}s in Sweden: ${count} across ${cityCount} cities. See prices, opening hours and book directly.`;

const faqs = [
  {
    q: `What is a ${labelLc}?`,
    a: TYPE_INTRO[type],
  },
  {
    q: `How many ${labelLc}s are there?`,
    a: `We list ${count} ${labelLc}s across ${cityCount} Swedish cities. The list is updated continuously.`,
  },
];

const jsonLd = buildGraph([
  organizationNode(),
  websiteNode(),
  breadcrumbNode([
    { label: "Home", url: "/" },
    { label: "Sauna finder", url: "/sauna-finder/" },
    { label, url: `/sauna-finder/type/${type}/` },
  ]),
  itemListNode({
    name: `${label}s in Sweden`,
    items: list.map((s) => ({ name: s.name, url: `/sauna-finder/${s.slug}/` })),
  }),
  faqNode(faqs),
]);
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="border-b border-ink-100 bg-sand-50">
    <div class="editorial-container py-8 md:py-12">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Sauna finder", href: "/sauna-finder/" },
          { label },
        ]}
      />
      <h1 class="text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">{label}s in Sweden</h1>
      <p class="mt-3 max-w-2xl text-lg leading-8 text-ink-600">
        {TYPE_INTRO[type]} We list {count} across {cityCount} {cityCount === 1 ? "city" : "cities"}.
      </p>
    </div>
  </div>

  <div class="editorial-container grid gap-8 py-10 md:py-14 lg:grid-cols-[minmax(0,1fr)_1.1fr]">
    <div class="order-2 lg:order-1">
      <h2 class="mb-4 text-sm font-semibold tracking-wide text-ink-500 uppercase">{count} {labelLc}s</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
        {list.map((s) => <SaunaCard sauna={s} />)}
      </div>
    </div>
    <div class="order-1 lg:order-2">
      <div class="lg:sticky lg:top-24">
        <FinderMap saunas={list} heightClass="h-[50vh] lg:h-[68vh]" />
      </div>
    </div>
  </div>

  <section class="border-t border-ink-100 bg-sand-50/60">
    <div class="editorial-container py-10 md:py-14">
      <h2 class="text-xl font-bold text-ink-900">Frequently asked questions</h2>
      <dl class="mt-4 max-w-3xl space-y-4">
        {faqs.map((f) => (
          <div class="rounded-2xl border border-ink-100 bg-white p-5">
            <dt class="font-semibold text-ink-900">{f.q}</dt>
            <dd class="mt-1.5 text-ink-600">{f.a}</dd>
          </div>
        ))}
      </dl>

      {citiesHere.length > 0 && (
        <>
          <h2 class="mt-10 text-xl font-bold text-ink-900">{label}s by city</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {citiesHere.map((c) => (
              <a href={`/sauna-finder/city/${c.slug}/`} class="rounded-full border border-ink-200 bg-white px-3.5 py-1.5 text-sm font-medium text-ink-700 no-underline transition-colors hover:border-brand-300 hover:text-brand-700">
                {c.city}
              </a>
            ))}
          </div>
        </>
      )}

      {otherTypes.length > 0 && (
        <>
          <h2 class="mt-10 text-xl font-bold text-ink-900">Other types of sauna</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {otherTypes.map((t) => (
              <a href={`/sauna-finder/type/${t.type}/`} class="rounded-full border border-ink-200 bg-white px-3.5 py-1.5 text-sm font-medium text-ink-700 no-underline transition-colors hover:border-brand-300 hover:text-brand-700">
                {TYPE_LABELS[t.type]} <span class="text-ink-400">({t.count})</span>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>
