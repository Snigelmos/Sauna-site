---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import SaunaCard from "@components/finder/SaunaCard.astro";
import FinderMap from "@components/finder/FinderMap.astro";
import {
  SAUNAS,
  TYPE_LABELS,
  cityHubs,
  citySlug,
  type Sauna,
} from "@data/saunas";
import {
  buildGraph,
  organizationNode,
  websiteNode,
  breadcrumbNode,
  itemListNode,
  faqNode,
} from "@components/schema/helpers";

export function getStaticPaths() {
  return cityHubs(1).map(({ city, slug }) => ({
    params: { city: slug },
    props: { city },
  }));
}

interface Props {
  city: string;
}
const { city } = Astro.props;

const list: Sauna[] = SAUNAS.filter((s) => s.city === city).sort(
  (a, b) =>
    Number(!!b.featured) - Number(!!a.featured) ||
    Number(b.bookable) - Number(a.bookable) ||
    a.name.localeCompare(b.name, "sv")
);
const count = list.length;
const bookable = list.filter((s) => s.bookable).length;

// type breakdown present in this city, for internal links
const typesHere = [...new Set(list.map((s) => s.type))];

// other cities to cross-link
const otherCities = cityHubs(1)
  .filter((c) => c.city !== city)
  .slice(0, 12);

const title = `Saunas in ${city} - find and book (${count})`;
const description = `Find a sauna in ${city}: ${count} saunas, cold bath houses and spas on the map. See prices, opening hours and book directly with each venue.`;

const faqs = [
  {
    q: `How many saunas are there in ${city}?`,
    a: `We list ${count} saunas in ${city}, of which ${bookable} can be booked online or by phone. The list is updated continuously from open sources.`,
  },
  {
    q: `Can you book a sauna in ${city}?`,
    a:
      bookable > 0
        ? `Yes, ${bookable} of the saunas in ${city} can be booked. Open a sauna to book directly with the venue.`
        : `Right now we don't list any pre-bookable saunas in ${city}, but several accept drop-ins. Check with each venue.`,
  },
];

const jsonLd = buildGraph([
  organizationNode(),
  websiteNode(),
  breadcrumbNode([
    { label: "Home", url: "/" },
    { label: "Sauna finder", url: "/sauna-finder/" },
    { label: `Saunas in ${city}`, url: `/sauna-finder/city/${citySlug(city)}/` },
  ]),
  itemListNode({
    name: `Saunas in ${city}`,
    items: list.map((s) => ({ name: s.name, url: `/sauna-finder/${s.slug}/` })),
  }),
  faqNode(faqs),
]);
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} noindex={count < 3}>
  <div class="border-b border-ink-100 bg-sand-50">
    <div class="editorial-container py-8 md:py-12">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Sauna finder", href: "/sauna-finder/" },
          { label: `Saunas in ${city}` },
        ]}
      />
      <h1 class="text-3xl font-bold tracking-tight text-ink-900 md:text-5xl">Saunas in {city}</h1>
      <p class="mt-3 max-w-2xl text-lg leading-8 text-ink-600">
        {count} {count === 1 ? "sauna" : "saunas"} in {city} - public saunas, cold bath houses and spas.
        {bookable > 0 ? ` ${bookable} can be booked.` : " Several accept drop-ins."} See prices and opening hours and book directly with the venue.
      </p>
      {typesHere.length > 1 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {typesHere.map((t) => (
            <a href={`/sauna-finder/type/${t}/`} class="rounded-full border border-ink-200 bg-white px-3.5 py-1.5 text-sm font-medium text-ink-700 no-underline transition-colors hover:border-brand-300 hover:text-brand-700">
              {TYPE_LABELS[t]}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="editorial-container grid gap-8 py-10 md:py-14 lg:grid-cols-[minmax(0,1fr)_1.1fr]">
    <div class="order-2 lg:order-1">
      <h2 class="mb-4 text-sm font-semibold tracking-wide text-ink-500 uppercase">{count} saunas</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
        {list.map((s) => <SaunaCard sauna={s} />)}
      </div>
    </div>
    <div class="order-1 lg:order-2">
      <div class="lg:sticky lg:top-24">
        <FinderMap saunas={list} heightClass="h-[50vh] lg:h-[68vh]" />
      </div>
    </div>
  </div>

  <section class="border-t border-ink-100 bg-sand-50/60">
    <div class="editorial-container py-10 md:py-14">
      <h2 class="text-xl font-bold text-ink-900">Frequently asked questions</h2>
      <dl class="mt-4 max-w-3xl space-y-4">
        {faqs.map((f) => (
          <div class="rounded-2xl border border-ink-100 bg-white p-5">
            <dt class="font-semibold text-ink-900">{f.q}</dt>
            <dd class="mt-1.5 text-ink-600">{f.a}</dd>
          </div>
        ))}
      </dl>

      {otherCities.length > 0 && (
        <>
          <h2 class="mt-10 text-xl font-bold text-ink-900">Saunas in other cities</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {otherCities.map((c) => (
              <a href={`/sauna-finder/city/${c.slug}/`} class="rounded-full border border-ink-200 bg-white px-3.5 py-1.5 text-sm font-medium text-ink-700 no-underline transition-colors hover:border-brand-300 hover:text-brand-700">
                {c.city} <span class="text-ink-400">({c.count})</span>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>
