 * ASINs). Swap to a specific product URL later. */
const buyLink = (query: string, label: string) =>
  `<a class="cmp-buy" href="${amazonSearchUrl(query)}" target="_blank" rel="nofollow sponsored noopener" data-evt="affiliate_click" data-evt-label="${label}">Check price &rarr;</a>`;

