const heroGuides = {
  heading: "Jump to",
  items: [
    { award: "Decide", title: "Pod vs blanket", href: "#pod-vs-blanket" },
    { award: "Expect", title: "Heat & sessions", href: "#what-to-expect" },
    { award: "Compare", title: "10 models compared", href: "#best-portable" },
