    ]}
    pros={[
      "Best balance of price and quality",
      "Washable insert = easy to keep fresh",
      "Reliable temperature control",
    ]}
    cons={[
      "Pricier than budget blankets",
      "Still a lie-still experience",
      "No steam or high heat",
    ]}
