---
import { SITE, HUBS } from "@config/site";
import LogoMark from "./LogoMark.astro";
const path = Astro.url.pathname;

const primaryLinks = [
  { href: "/home-sauna/", label: "Home saunas", match: "/home-sauna" },
  { href: "/outdoor-sauna/", label: "Outdoor", match: "/outdoor-sauna" },
  { href: "/portable-sauna/", label: "Portable", match: "/portable-sauna" },
  { href: "/sauna-kits/", label: "DIY builds", match: "/sauna-kits" },
  { href: "/sauna-guide/", label: "Sauna guide", match: "/sauna-guide" },
];
const calcActive = path.startsWith("/tools/");
---

<header
  class="sticky top-0 z-40 border-b border-ink-100/70 bg-white/70 backdrop-blur-md"
  style="padding-top: env(safe-area-inset-top, 0px);"
>
  <div class="editorial-container flex items-center justify-between gap-4 py-2.5 md:py-4">
    <a href="/" class="flex items-center gap-2.5 text-ink-900 no-underline" aria-label={SITE.name}>
      <span class="md:hidden"><LogoMark size={30} /></span>
      <span class="hidden md:inline-flex"><LogoMark size={36} /></span>
      <span class="hidden text-[15px] font-semibold tracking-tight whitespace-nowrap sm:inline-block">
        {SITE.name}
      </span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex flex-nowrap items-center gap-1 text-sm whitespace-nowrap">
        {
          primaryLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "rounded-full px-3 py-2 no-underline transition-colors",
                  path.startsWith(link.match)
                    ? "bg-brand-50 text-brand-800 font-semibold"
                    : "text-ink-700 hover:bg-ink-50 hover:text-ink-900",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="ml-2">
          <a
            href="/tools/sauna-cost-calculator/"
            aria-current={calcActive ? "page" : undefined}
            class:list={[
              "inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-semibold whitespace-nowrap no-underline shadow-sm transition-colors",
              calcActive
                ? "bg-brand-800 text-white"
                : "bg-brand-700 text-white hover:bg-brand-800",
            ]}
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="3" width="14" height="18" rx="2" />
              <line x1="9" y1="7" x2="15" y2="7" />
              <line x1="9" y1="11" x2="9.01" y2="11" />
              <line x1="12" y1="11" x2="12.01" y2="11" />
              <line x1="15" y1="11" x2="15.01" y2="11" />
              <line x1="9" y1="15" x2="9.01" y2="15" />
              <line x1="12" y1="15" x2="12.01" y2="15" />
              <line x1="15" y1="15" x2="15.01" y2="15" />
            </svg>
            Cost calculator
          </a>
        </li>
      </ul>
    </nav>

    <details class="relative md:hidden" data-mobile-nav>
      <summary
        class="flex min-h-11 cursor-pointer list-none items-center rounded-md border border-ink-200 px-3 py-2 text-sm font-medium text-ink-800"
        aria-label="Open menu"
        >Menu</summary
      >
      <ul
        class="absolute right-0 z-30 mt-2 w-64 rounded-md border border-ink-200 bg-white p-2 shadow-lg"
      >
        <li class="mb-1">
          <a
            href="/tools/sauna-cost-calculator/"
            class="flex min-h-11 items-center justify-center gap-1.5 rounded-md bg-brand-700 px-3 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-800"
            >Cost calculator</a
          >
        </li>
        {
          HUBS.map((h) => (
            <li>
              <a
                href={h.href}
                class="flex min-h-11 items-center rounded px-3 py-2 text-sm text-ink-800 no-underline hover:bg-ink-50"
              >
                {h.title}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/sauna-guide/"
            class="flex min-h-11 items-center rounded px-3 py-2 text-sm font-semibold text-ink-900 no-underline hover:bg-ink-50"
            >Sauna guide</a
          >
        </li>
        <li class="mt-1 border-t border-ink-100 pt-1">
          <a
            href="/about/"
            class="flex min-h-11 items-center rounded px-3 py-2 text-sm text-ink-700 no-underline hover:bg-ink-50"
            >About</a
          >
        </li>
        <li>
          <a
            href="/methodology/"
            class="flex min-h-11 items-center rounded px-3 py-2 text-sm text-ink-700 no-underline hover:bg-ink-50"
            >How we research</a
          >
        </li>
      </ul>
    </details>
  </div>

  <script>
    const nav = document.querySelector<HTMLDetailsElement>("details[data-mobile-nav]");
    if (nav) {
      nav.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest("a")) nav.open = false;
      });
      document.addEventListener("click", (e) => {
        if (!nav.open) return;
        if (!nav.contains(e.target as Node)) nav.open = false;
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && nav.open) {
          nav.open = false;
          nav.querySelector<HTMLElement>("summary")?.focus();
        }
      });
    }
  </script>
</header>
