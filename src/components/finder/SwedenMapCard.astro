---
/*
 * Decorative, hand-crafted "map card" for the finder hero (non-interactive).
 * A soft cream Sweden silhouette on a calm blue water panel with amber pins,
 * echoing the reference design. The live, interactive map lives below the hero.
 */
export interface Props {
  count: number;
  class?: string;
}
const { count, class: className = "" } = Astro.props;

// Pin positions in the 220 x 380 viewBox (roughly Stockholm, Goteborg, Malmo).
const pins = [
  { x: 158, y: 196, big: true },
  { x: 150, y: 178, big: false },
  { x: 78, y: 286, big: true },
  { x: 86, y: 268, big: false },
  { x: 96, y: 330, big: false },
];
const cities = [
  { x: 168, y: 200, label: "Stockholm" },
  { x: 56, y: 292, label: "Göteborg" },
  { x: 104, y: 336, label: "Malmö" },
];
---

<div
  class:list={[
    "relative overflow-hidden rounded-[2rem] border border-white/70 bg-[#cfe0ea] p-5 shadow-[0_30px_80px_rgba(40,25,16,0.18)]",
    className,
  ]}
>
  <!-- floating "n saunas" pill -->
  <div class="absolute left-6 top-6 z-10 inline-flex items-center gap-2 rounded-full bg-white/90 px-3 py-1.5 text-xs font-semibold text-ink-700 shadow-sm backdrop-blur">
    <span class="relative flex h-2 w-2">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-ember-500 opacity-60"></span>
      <span class="relative inline-flex h-2 w-2 rounded-full bg-ember-500"></span>
    </span>
    {count} saunas on the map
  </div>

  <svg
    viewBox="0 0 220 380"
    role="img"
    aria-label="Map of Sweden with saunas marked"
    class="mx-auto block h-[22rem] w-auto md:h-[26rem]"
  >
    <defs>
      <linearGradient id="land" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#f7f1e6" />
        <stop offset="100%" stop-color="#ece1cd" />
      </linearGradient>
      <radialGradient id="water" cx="50%" cy="35%" r="80%">
        <stop offset="0%" stop-color="#d7e6ef" />
        <stop offset="100%" stop-color="#c2d6e2" />
      </radialGradient>
      <filter id="pinShadow" x="-50%" y="-50%" width="200%" height="200%">
        <feDropShadow dx="0" dy="2.5" stdDeviation="2" flood-color="#1c130d" flood-opacity="0.28" />
      </filter>
    </defs>

    <rect x="0" y="0" width="220" height="380" rx="20" fill="url(#water)" />

    <!-- stylized Sweden landmass -->
    <path
      d="M150 14
         C160 30 150 50 156 66
         C162 84 178 96 176 118
         C174 140 156 150 158 172
         C160 196 178 206 172 230
         C168 250 150 256 146 278
         C142 300 150 318 132 336
         C120 348 110 360 100 360
         C92 360 90 348 84 340
         C76 330 64 330 60 318
         C55 302 70 292 66 276
         C62 258 44 254 46 234
         C48 214 66 210 64 190
         C62 168 42 162 46 138
         C49 118 68 116 72 96
         C76 76 64 60 74 44
         C82 30 100 32 112 24
         C124 16 140 6 150 14 Z"
      fill="url(#land)"
      stroke="#d8c8ac"
      stroke-width="1.5"
    />

    <!-- city labels -->
    {cities.map((c) => (
      <text
        x={c.x}
        y={c.y}
        font-size="9"
        font-weight="600"
        fill="#7c6f5a"
        text-anchor="start"
      >{c.label}</text>
    ))}

    <!-- pins -->
    {pins.map((p) => (
      <g filter="url(#pinShadow)" transform={`translate(${p.x} ${p.y})`}>
        <path
          d={p.big
            ? "M0 -22 C7.7 -22 14 -15.7 14 -8 C14 1.5 0 14 0 14 C0 14 -14 1.5 -14 -8 C-14 -15.7 -7.7 -22 0 -22 Z"
            : "M0 -17 C6 -17 11 -12 11 -6 C11 1 0 11 0 11 C0 11 -11 1 -11 -6 C-11 -12 -6 -17 0 -17 Z"}
          fill="#c64f15"
        />
        <circle cx="0" cy={p.big ? -8 : -6} r={p.big ? 5 : 4} fill="#fff" />
      </g>
    ))}
  </svg>

  <div class="mt-2 flex items-center justify-between rounded-2xl bg-white/85 px-4 py-3 backdrop-blur">
    <div>
      <p class="text-sm font-semibold text-ink-900">Open the map</p>
      <p class="text-xs text-ink-500">Find saunas near you</p>
    </div>
    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-ink-900 text-white">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>
</div>
