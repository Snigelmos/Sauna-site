---
import { AFFILIATE } from "@config/affiliate";
export interface Props {
  variant?: "full" | "short";
}
const { variant = "full" } = Astro.props;
const text = variant === "full" ? AFFILIATE.disclosure : AFFILIATE.shortDisclosure;
---

<aside
  class="my-6 rounded-md border-l-4 border-brand-400 bg-brand-50/60 px-4 py-3 text-sm text-brand-900"
  aria-label="Affiliate disclosure"
>
  <strong class="mr-1">Disclosure:</strong>{text}
  <a class="ml-1 underline hover:text-brand-700" href="/disclosure/">Read full disclosure</a>.
</aside>
