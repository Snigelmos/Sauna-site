---
import { SITE, HUBS } from "@config/site";
import LogoMark from "./LogoMark.astro";
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-ink-100 bg-white">
  <div class="editorial-container grid gap-10 py-12 md:grid-cols-4">
    <div class="md:col-span-1">
      <div class="flex items-center gap-2.5">
        <LogoMark size={36} />
        <span class="font-semibold text-ink-900">{SITE.name}</span>
      </div>
      <p class="mt-3 text-sm text-ink-700">
        Independent buyer guides for home saunas. We compare formats by home type, budget, space,
        and electrical needs, disclose every affiliate link, and never fake testing or ratings.
      </p>
      <p class="mt-2 text-sm text-ink-700">
        Edited by the
        <a class="font-medium text-ink-900 no-underline hover:text-brand-700" href="/about/">{SITE.author.name}</a>.
        Email
        <a class="no-underline hover:text-brand-700" href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.
      </p>
    </div>

    <div>
      <h2 class="text-xs font-semibold tracking-wider text-ink-500 uppercase">Categories</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          HUBS.map((h) => (
            <li>
              <a class="text-ink-700 no-underline hover:text-brand-700" href={h.href}>
                {h.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-xs font-semibold tracking-wider text-ink-500 uppercase">Tools &amp; site</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/sauna-guide/">Sauna guide</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/cold-plunge/">Cold plunge &amp; contrast therapy</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/tools/sauna-cost-calculator/">Sauna cost calculator</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/sauna-finder/">Sauna finder (pilot)</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/about/">About</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/methodology/">Methodology</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/contact/">Contact</a>
        </li>
      </ul>
    </div>

    <div>
      <h2 class="text-xs font-semibold tracking-wider text-ink-500 uppercase">Legal</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/disclosure/">Affiliate disclosure</a>
        </li>
        <li>
          <a class="text-ink-700 no-underline hover:text-brand-700" href="/privacy/">Privacy</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-ink-100">
    <div
      class="editorial-container flex flex-col gap-2 py-4 text-xs text-ink-500 md:flex-row md:items-center md:justify-between"
    >
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <p>
        As an Amazon Associate we may earn from qualifying purchases. See our
        <a class="underline hover:text-brand-700" href="/disclosure/">disclosure</a>.
      </p>
    </div>
  </div>
</footer>
