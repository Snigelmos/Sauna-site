---
export interface Props {
  items: { q: string; a: string }[];
  heading?: string;
  id?: string;
}
const { items, heading = "Frequently asked questions", id = "faq" } = Astro.props;
---

<section id={id} aria-labelledby={`${id}-heading`} class="mt-12">
  <h2 id={`${id}-heading`} class="text-2xl font-semibold tracking-tight text-ink-900">
    {heading}
  </h2>
  <div class="mt-4 divide-y divide-ink-100 rounded-lg border border-ink-100">
    {
      items.map((item, i) => (
        <details class="group [&[open]]:bg-ink-50/40" open={i === 0}>
          <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 text-base font-medium text-ink-900">
            <span>{item.q}</span>
            <span
              aria-hidden="true"
              class="text-ink-500 transition-transform group-open:rotate-45"
            >
              +
            </span>
          </summary>
          <div class="px-4 pt-1 pb-4 text-sm leading-relaxed text-ink-700" set:html={item.a} />
        </details>
      ))
    }
  </div>
</section>
