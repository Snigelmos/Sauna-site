---
export interface Crumb {
  label: string;
  href?: string;
}
export interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-4 text-sm text-ink-600">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((c, i) => (
        <li class="flex items-center gap-1">
          {c.href && i < items.length - 1 ? (
            <a class="text-ink-600 hover:text-brand-700" href={c.href}>
              {c.label}
            </a>
          ) : (
            <span class="text-ink-700" aria-current={i === items.length - 1 ? "page" : undefined}>
              {c.label}
            </span>
          )}
          {i < items.length - 1 && <span aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
