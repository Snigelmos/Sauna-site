---
export interface Props {
  variant?: "note" | "warning" | "tip";
  title?: string;
}
const { variant = "note", title } = Astro.props;

const styles: Record<NonNullable<Props["variant"]>, { wrap: string; label: string; icon: string }> = {
  note: {
    wrap: "border-brand-300 bg-brand-50/60 text-brand-900",
    label: "Note",
    icon: "i",
  },
  warning: {
    wrap: "border-amber-300 bg-amber-50 text-amber-900",
    label: "Important",
    icon: "!",
  },
  tip: {
    wrap: "border-emerald-300 bg-emerald-50 text-emerald-900",
    label: "Tip",
    icon: "+",
  },
};
const s = styles[variant];
---

<aside class:list={["my-6 rounded-md border-l-4 px-4 py-3", s.wrap]}>
  <p class="flex items-center gap-2 text-sm font-semibold">
    <span
      aria-hidden="true"
      class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-current text-xs"
      >{s.icon}</span
    >
    {title ?? s.label}
  </p>
  <div class="mt-1 text-sm">
    <slot />
  </div>
</aside>
