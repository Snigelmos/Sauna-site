# Keep root-level research and SEO source material out of the deployment.
# Anchored to the repo root so src/data and src/research-style folders are
# never stripped.
/data/
/research/
/briefs/

# Build/harvest scripts (Vercel runs npm scripts, not these directly)
/scripts/

# Editor / local-only
/.cursor/
/.github/

# Local preview output and logs
preview-*.html
*.log
*.err

# Internal markdown docs (none are served by the site)
*.md
!README.md
